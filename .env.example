# ─────────────────────────────────────────
# World Cortisol Index — Environment Config
# ─────────────────────────────────────────
# Copy this file to `.env` and fill in your API keys.
# Get free keys from:
#   GNews:    https://gnews.io/      (100 req/day free)
#   NewsData: https://newsdata.io/   (200 req/day free)
#   NewsAPI:  https://newsapi.org/   (100 req/day free, dev only)
#
# GDELT does NOT require a key — it's free and public.

# Server port (default 3000)
PORT=3000

# News API keys (server-side only — never exposed to client)
GNEWS_KEY=your_gnews_key_here
NEWSDATA_KEY=your_newsdata_key_here
NEWSAPI_KEY=your_newsapi_key_here

# Cache TTL for news responses, in seconds.
# News APIs have low daily quotas — caching for 5–10 minutes is reasonable.
CACHE_TTL_SECONDS=300

# Per-API request timeout, in ms
API_TIMEOUT_MS=12000
